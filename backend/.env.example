# MkController - Configuración de Entorno
# Copia este archivo como .env y ajusta los valores

# Puerto del servidor (cPanel usualmente asigna dinámicamente)
PORT=3000

# Secreto JWT - CAMBIA ESTO en producción
JWT_SECRET=tu_secreto_jwt_muy_seguro_aqui_12345

# Expiración del token JWT
JWT_EXPIRES_IN=24h

# Origen permitido para CORS (dominio del frontend)
CORS_ORIGIN=https://nexusmk.nexussolutionsyl.com

# Configuración MySQL para nexusMK
DB_MYSQL_HOST=localhost
DB_MYSQL_USER=nexuyl_nexusmk
DB_MYSQL_PASSWORD=tu_password_mysql
DB_MYSQL_DATABASE=nexuyl_nexusmk

# Configuración MikroTik REST API v7 para ISP Manager
# Host: IP o dominio del RouterOS (ej: 192.168.88.1 o router.midominio.com)
ISP_MIKROTIK_HOST=127.0.0.1
ISP_MIKROTIK_PORT=443
ISP_MIKROTIK_USER=admin
ISP_MIKROTIK_PASSWORD=tu_password_routeros
ISP_MIKROTIK_SSL=true
ISP_MIKROTIK_TIMEOUT=10000

# Configuración de Telegram para alertas ISP (opcional)
ISP_TELEGRAM_BOT_TOKEN=
ISP_TELEGRAM_CHAT_ID=
